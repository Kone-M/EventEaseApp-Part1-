@model EventEaseApp.Models.Venue

@{
    ViewData["Title"] = "Venue Details";
}

<div class="container">
    <h1>Venue Details</h1>

    <div class="card mb-4">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" class="card-img-top" alt="@Model.VenueName" style="max-height: 400px; object-fit: cover;">
        }
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.VenueName)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.VenueName)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Location)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Location)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Capacity)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Capacity)</dd>
            </dl>
        </div>
    </div>

    @if (Model.Bookings != null && Model.Bookings.Any())
    {
        <div class="card mt-4">
            <div class="card-header">
                <h5>Bookings for this Venue</h5>
            </div>
            <div class="card-body">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Booking ID</th>
                            <th>Event</th>
                            <th>Booking Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var booking in Model.Bookings)
                        {
                            <tr>
                                <td>@booking.BookingId</td>
                                <td>@booking.Event?.EventName</td>
                                <td>@booking.BookingDate.ToString("yyyy-MM-dd HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <div class="mt-3">
        <a asp-action="Edit" asp-route-id="@Model.VenueId" class="btn btn-warning">Edit</a>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</div>