@model EventEaseApp.Models.Venue

@{
    ViewData["Title"] = "Delete Venue";
}

<div class="container">
    <h1>Delete Venue</h1>

    <div class="alert alert-danger">
        <h3>Are you sure you want to delete this venue?</h3>
    </div>

    <div class="card">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.VenueName)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.VenueName)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Location)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Location)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Capacity)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Capacity)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ImageUrl)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.ImageUrl)</dd>
            </dl>

            <form asp-action="Delete">
                <input type="hidden" asp-for="VenueId" />
                <input type="submit" value="Delete" class="btn btn-danger" />
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>