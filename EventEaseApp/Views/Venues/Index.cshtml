@model IEnumerable<EventEaseApp.Models.Venue>

@{
    ViewData["Title"] = "Venues";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>
        <span style="font-size: 2.5rem;">🏛️</span>
        Venues
        <span style="font-size: 2rem;">🏢</span>
    </h1>
    <a asp-action="Create" class="btn btn-primary">
        <span style="font-size: 1.2rem;">➕</span> Create New Venue
    </a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <span style="font-size: 1.2rem;">⚠️</span>
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info text-center py-5">
        <div style="font-size: 4rem; margin-bottom: 1rem;">🏛️</div>
        <h3>No Venues Found</h3>
        <p class="lead mb-4">Get started by creating your first venue!</p>
        <a asp-action="Create" class="btn btn-primary btn-lg">
            <span style="font-size: 1.2rem;">➕</span> Create Your First Venue
        </a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-primary">
                <tr>
                    <th><span style="font-size: 1.2rem;">🏷️</span> @Html.DisplayNameFor(model => model.VenueName)</th>
                    <th><span style="font-size: 1.2rem;">📍</span> @Html.DisplayNameFor(model => model.Location)</th>
                    <th><span style="font-size: 1.2rem;">👥</span> @Html.DisplayNameFor(model => model.Capacity)</th>
                    <th><span style="font-size: 1.2rem;">🖼️</span> Image</th>
                    <th><span style="font-size: 1.2rem;">⚙️</span> Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold">
                            <span style="font-size: 1.1rem;">🏛️</span>
                            @Html.DisplayFor(modelItem => item.VenueName)
                        </td>
                        <td>
                            <span style="font-size: 1.1rem;">📍</span>
                            @Html.DisplayFor(modelItem => item.Location)
                        </td>
                        <td>
                            <span style="font-size: 1.1rem;">👥</span>
                            @Html.DisplayFor(modelItem => item.Capacity)
                            <span class="text-muted">people</span>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <div class="position-relative">
                                    <img src="@item.ImageUrl" alt="@item.VenueName"
                                         style="max-width: 100px; max-height: 60px; object-fit: cover; border-radius: 4px;"
                                         class="border" />
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-primary"
                                          style="font-size: 0.8rem;">
                                        🖼️
                                    </span>
                                </div>
                            }
                            else
                            {
                                <span class="text-muted">
                                    <span style="font-size: 1.5rem;">🚫</span> No image
                                </span>
                            }
                        </td>
                        <td>
                            <div class="btn-group" role="group">
                                <a asp-action="Edit" asp-route-id="@item.VenueId"
                                   class="btn btn-sm btn-warning"
                                   title="Edit Venue">
                                    <span style="font-size: 1.1rem;">✏️</span> Edit
                                </a>
                                <a asp-action="Details" asp-route-id="@item.VenueId"
                                   class="btn btn-sm btn-info"
                                   title="View Details">
                                    <span style="font-size: 1.1rem;">🔍</span> Details
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.VenueId"
                                   class="btn btn-sm btn-danger"
                                   title="Delete Venue"
                                   onclick="return confirm('Are you sure you want to delete this venue? ⚠️');">
                                    <span style="font-size: 1.1rem;">🗑️</span> Delete
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card bg-light-blue border-primary">
                <div class="card-body">
                    <h5 class="card-title text-primary">
                        <span style="font-size: 1.5rem;">📊</span> Venue Summary
                    </h5>
                    <div class="d-flex justify-content-around text-center">
                        <div>
                            <div class="display-6 text-primary">🏛️</div>
                            <div>Total Venues</div>
                            <div class="h3 text-primary">@Model.Count()</div>
                        </div>
                        <div>
                            <div class="display-6 text-primary">👥</div>
                            <div>Total Capacity</div>
                            <div class="h3 text-primary">@Model.Sum(v => v.Capacity).ToString("N0")</div>
                        </div>
                        <div>
                            <div class="display-6 text-primary">📍</div>
                            <div>Avg Capacity</div>
                            <div class="h3 text-primary">@((int)Model.Average(v => v.Capacity))</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card bg-light-blue border-primary">
                <div class="card-body">
                    <h5 class="card-title text-primary">
                        <span style="font-size: 1.5rem;">ℹ️</span> Quick Tips
                    </h5>
                    <ul class="list-unstyled mb-0">
                        <li><span style="font-size: 1.1rem;">✅</span> Click <strong>Edit</strong> ✏️ to modify venue details</li>
                        <li><span style="font-size: 1.1rem;">✅</span> Click <strong>Details</strong> 🔍 to view full information</li>
                        <li><span style="font-size: 1.1rem;">✅</span> Click <strong>Delete</strong> 🗑️ to remove a venue</li>
                        <li><span style="font-size: 1.1rem;">➕</span> Use the <strong>Create New</strong> button to add venues</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
}