@model IEnumerable<EventEaseApp.Models.Event>

@{
    ViewData["Title"] = "Events";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>
            <span style="font-size: 2.5rem;">🎉</span>
            Events
            <span style="font-size: 2rem;">🎪</span>
        </h1>
        <a asp-action="Create" class="btn btn-primary">
            <span style="font-size: 1.2rem;">➕</span> Create New Event
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <span style="font-size: 1.2rem;">⚠️</span>
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center py-5">
            <div style="font-size: 4rem; margin-bottom: 1rem;">🎉</div>
            <h3>No Events Found</h3>
            <p class="lead mb-4">Get started by creating your first event!</p>
            <a asp-action="Create" class="btn btn-primary btn-lg">
                <span style="font-size: 1.2rem;">➕</span> Create Your First Event
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-primary">
                    <tr>
                        <th><span style="font-size: 1.2rem;">🏷️</span> @Html.DisplayNameFor(model => model.EventName)</th>
                        <th><span style="font-size: 1.2rem;">📅</span> @Html.DisplayNameFor(model => model.EventDate)</th>
                        <th><span style="font-size: 1.2rem;">📝</span> @Html.DisplayNameFor(model => model.Description)</th>
                        <th><span style="font-size: 1.2rem;">🏛️</span> Venue</th>
                        <th><span style="font-size: 1.2rem;">⚙️</span> Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">
                                <span style="font-size: 1.1rem;">🎪</span>
                                @Html.DisplayFor(modelItem => item.EventName)
                            </td>
                            <td>
                                <span style="font-size: 1.1rem;">📆</span>
                                @item.EventDate.ToString("yyyy-MM-dd HH:mm")
                                @if (item.EventDate > DateTime.Now)
                                {
                                    <span class="badge bg-success ms-2">
                                        <span style="font-size: 0.9rem;">✅</span> Upcoming
                                    </span>
                                }
                                else if (item.EventDate < DateTime.Now)
                                {
                                    <span class="badge bg-secondary ms-2">
                                        <span style="font-size: 0.9rem;">⌛</span> Past
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark ms-2">
                                        <span style="font-size: 0.9rem;">🔥</span> Today
                                    </span>
                                }
                            </td>
                            <td>
                                @{
                                    var description = item.Description ?? "";
                                    var shortDescription = description.Length > 50
                                    ? description.Substring(0, 47) + "..."
                                    : description;
                                }
                                <span title="@description">
                                    <span style="font-size: 1.1rem;">📋</span>
                                    @shortDescription
                                </span>
                            </td>
                            <td>
                                @if (item.Venue != null)
                                {
                                    <span>
                                        <span style="font-size: 1.1rem;">🏛️</span>
                                        @item.Venue.VenueName
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">
                                        <span style="font-size: 1.1rem;">🚫</span> Not assigned
                                    </span>
                                }
                            </td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="Edit" asp-route-id="@item.EventId"
                                       class="btn btn-sm btn-warning"
                                       title="Edit Event">
                                        <span style="font-size: 1.1rem;">✏️</span> Edit
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.EventId"
                                       class="btn btn-sm btn-info"
                                       title="View Details">
                                        <span style="font-size: 1.1rem;">🔍</span> Details
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.EventId"
                                       class="btn btn-sm btn-danger"
                                       title="Delete Event"
                                       onclick="return confirm('Are you sure you want to delete this event? ⚠️');">
                                        <span style="font-size: 1.1rem;">🗑️</span> Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="row mt-4">
            <div class="col-md-6">
                <div class="card bg-light-blue border-primary">
                    <div class="card-body">
                        <h5 class="card-title text-primary">
                            <span style="font-size: 1.5rem;">📊</span> Event Summary
                        </h5>
                        <div class="d-flex justify-content-around text-center">
                            <div>
                                <div class="display-6 text-primary">🎉</div>
                                <div>Total Events</div>
                                <div class="h3 text-primary">@Model.Count()</div>
                            </div>
                            <div>
                                <div class="display-6 text-primary">✅</div>
                                <div>Upcoming</div>
                                <div class="h3 text-primary">
                                    @Model.Count(e => e.EventDate > DateTime.Now)
                                </div>
                            </div>
                            <div>
                                <div class="display-6 text-primary">⌛</div>
                                <div>Past</div>
                                <div class="h3 text-primary">
                                    @Model.Count(e => e.EventDate < DateTime.Now)
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card bg-light-blue border-primary">
                    <div class="card-body">
                        <h5 class="card-title text-primary">
                            <span style="font-size: 1.5rem;">📅</span> Next Events
                        </h5>
                        @{
                            var nextEvents = Model
                            .Where(e => e.EventDate > DateTime.Now)
                            .OrderBy(e => e.EventDate)
                            .Take(3);
                        }
                        @if (nextEvents.Any())
                        {
                            <ul class="list-unstyled mb-0">
                                @foreach (var nextEvent in nextEvents)
                                {
                                    <li class="mb-2">
                                        <span style="font-size: 1.1rem;">🔜</span>
                                        <strong>@nextEvent.EventName</strong> -
                                        @nextEvent.EventDate.ToString("MMM dd, yyyy")
                                        @if (nextEvent.Venue != null)
                                        {
                                            <span class="text-muted">
                                                <span style="font-size: 1rem;">🏛️</span>
                                                @nextEvent.Venue.VenueName
                                            </span>
                                        }
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p class="text-muted mb-0">
                                <span style="font-size: 1.1rem;">😴</span> No upcoming events
                            </p>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-4">
            <div class="col-12">
                <div class="card bg-light-blue border-primary">
                    <div class="card-body">
                        <h5 class="card-title text-primary">
                            <span style="font-size: 1.5rem;">ℹ️</span> Quick Tips
                        </h5>
                        <div class="row">
                            <div class="col-md-6">
                                <ul class="list-unstyled mb-0">
                                    <li><span style="font-size: 1.1rem;">✅</span> Click <strong>Edit</strong> ✏️ to modify event details</li>
                                    <li><span style="font-size: 1.1rem;">✅</span> Click <strong>Details</strong> 🔍 to view full information</li>
                                    <li><span style="font-size: 1.1rem;">✅</span> Click <strong>Delete</strong> 🗑️ to remove an event</li>
                                </ul>
                            </div>
                            <div class="col-md-6">
                                <ul class="list-unstyled mb-0">
                                    <li><span style="font-size: 1.1rem;">✅</span> <span class="badge bg-success">✅ Upcoming</span> - Future events</li>
                                    <li><span style="font-size: 1.1rem;">✅</span> <span class="badge bg-secondary">⌛ Past</span> - Completed events</li>
                                    <li><span style="font-size: 1.1rem;">✅</span> <span class="badge bg-warning text-dark">🔥 Today</span> - Events happening now</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>