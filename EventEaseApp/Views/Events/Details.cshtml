@model EventEaseApp.Models.Event

@{
    ViewData["Title"] = "Event Details";
}

<div class="container">
    <h1>Event Details</h1>

    <div class="card">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.EventName)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.EventName)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.EventDate)</dt>
                <dd class="col-sm-9">@Model.EventDate.ToString("yyyy-MM-dd HH:mm")</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Description)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Description)</dd>

                <dt class="col-sm-3">Venue</dt>
                <dd class="col-sm-9">
                    @if (Model.Venue != null)
                    {
                        <a asp-controller="Venues" asp-action="Details" asp-route-id="@Model.VenueId">
                            @Model.Venue.VenueName
                        </a>
                    }
                    else
                    {
                        <span class="text-muted">Not assigned to a venue</span>
                    }
                </dd>
            </dl>
        </div>
    </div>

    @if (Model.Bookings != null && Model.Bookings.Any())
    {
        <div class="card mt-4">
            <div class="card-header">
                <h5>Bookings for this Event</h5>
            </div>
            <div class="card-body">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Booking ID</th>
                            <th>Venue</th>
                            <th>Booking Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var booking in Model.Bookings)
                        {
                            <tr>
                                <td>@booking.BookingId</td>
                                <td>@booking.Venue?.VenueName</td>
                                <td>@booking.BookingDate.ToString("yyyy-MM-dd HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <div class="mt-3">
        <a asp-action="Edit" asp-route-id="@Model.EventId" class="btn btn-warning">Edit</a>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</div>