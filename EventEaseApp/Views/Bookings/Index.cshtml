@model IEnumerable<EventEaseApp.Models.Booking>

@{
    ViewData["Title"] = "Bookings";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>
            <span style="font-size: 2.5rem;">📆</span>
            Bookings
            <span style="font-size: 2rem;">✅</span>
        </h1>
        <a asp-action="Create" class="btn btn-primary">
            <span style="font-size: 1.2rem;">➕</span> Create New Booking
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <span style="font-size: 1.2rem;">⚠️</span>
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <span style="font-size: 1.2rem;">✅</span>
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center py-5">
            <div style="font-size: 4rem; margin-bottom: 1rem;">📅</div>
            <h3>No Bookings Found</h3>
            <p class="lead mb-4">Get started by creating your first booking!</p>
            <a asp-action="Create" class="btn btn-primary btn-lg">
                <span style="font-size: 1.2rem;">➕</span> Create Your First Booking
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-primary">
                    <tr>
                        <th><span style="font-size: 1.2rem;">🆔</span> Booking ID</th>
                        <th><span style="font-size: 1.2rem;">🎉</span> Event</th>
                        <th><span style="font-size: 1.2rem;">🏛️</span> Venue</th>
                        <th><span style="font-size: 1.2rem;">📅</span> @Html.DisplayNameFor(model => model.BookingDate)</th>
                        <th><span style="font-size: 1.2rem;">⚙️</span> Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <span class="fw-bold">#@item.BookingId</span>
                                @if (item.BookingDate > DateTime.Now.AddDays(7))
                                {
                                    <span class="badge bg-info ms-2">
                                        <span style="font-size: 0.9rem;">🔮</span> Far out
                                    </span>
                                }
                                else if (item.BookingDate > DateTime.Now)
                                {
                                    <span class="badge bg-success ms-2">
                                        <span style="font-size: 0.9rem;">✅</span> Confirmed
                                    </span>
                                }
                                else if (item.BookingDate.Date == DateTime.Now.Date)
                                {
                                    <span class="badge bg-warning text-dark ms-2">
                                        <span style="font-size: 0.9rem;">🔥</span> Today
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary ms-2">
                                        <span style="font-size: 0.9rem;">⌛</span> Past
                                    </span>
                                }
                            </td>
                            <td>
                                @if (item.Event != null)
                                {
                                    <span>
                                        <span style="font-size: 1.1rem;">🎪</span>
                                        @item.Event.EventName
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">
                                        <span style="font-size: 1.1rem;">🚫</span> Event not found
                                    </span>
                                }
                            </td>
                            <td>
                                @if (item.Venue != null)
                                {
                                    <span>
                                        <span style="font-size: 1.1rem;">🏛️</span>
                                        @item.Venue.VenueName
                                        <br />
                                        <small class="text-muted">
                                            <span style="font-size: 0.9rem;">👥</span>
                                            Capacity: @item.Venue.Capacity
                                        </small>
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">
                                        <span style="font-size: 1.1rem;">🚫</span> Venue not found
                                    </span>
                                }
                            </td>
                            <td>
                                <span style="font-size: 1.1rem;">📆</span>
                                @item.BookingDate.ToString("yyyy-MM-dd HH:mm")
                                <br />
                                <small class="text-muted">
                                    @{
                                        var daysUntil = (item.BookingDate - DateTime.Now).Days;
                                        if (daysUntil > 0)
                                        {
                                            <span>📅 in @daysUntil days</span>
                                        }
                                        else if (daysUntil == 0)
                                        {
                                            <span>🔥 today!</span>
                                        }
                                    }
                                </small>
                            </td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="Edit" asp-route-id="@item.BookingId"
                                       class="btn btn-sm btn-warning"
                                       title="Edit Booking">
                                        <span style="font-size: 1.1rem;">✏️</span> Edit
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.BookingId"
                                       class="btn btn-sm btn-info"
                                       title="View Details">
                                        <span style="font-size: 1.1rem;">🔍</span> Details
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.BookingId"
                                       class="btn btn-sm btn-danger"
                                       title="Delete Booking"
                                       onclick="return confirm('Are you sure you want to delete this booking? ⚠️');">
                                        <span style="font-size: 1.1rem;">🗑️</span> Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="row mt-4">
            <div class="col-md-6">
                <div class="card bg-light-blue border-primary">
                    <div class="card-body">
                        <h5 class="card-title text-primary">
                            <span style="font-size: 1.5rem;">📊</span> Booking Summary
                        </h5>
                        <div class="d-flex justify-content-around text-center">
                            <div>
                                <div class="display-6 text-primary">📆</div>
                                <div>Total Bookings</div>
                                <div class="h3 text-primary">@Model.Count()</div>
                            </div>
                            <div>
                                <div class="display-6 text-primary">✅</div>
                                <div>Upcoming</div>
                                <div class="h3 text-primary">
                                    @Model.Count(b => b.BookingDate > DateTime.Now)
                                </div>
                            </div>
                            <div>
                                <div class="display-6 text-primary">⌛</div>
                                <div>Past</div>
                                <div class="h3 text-primary">
                                    @Model.Count(b => b.BookingDate < DateTime.Now)
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card bg-light-blue border-primary">
                    <div class="card-body">
                        <h5 class="card-title text-primary">
                            <span style="font-size: 1.5rem;">🎯</span> Today's Bookings
                        </h5>
                        @{
                            var todayBookings = Model
                            .Where(b => b.BookingDate.Date == DateTime.Now.Date)
                            .OrderBy(b => b.BookingDate);
                        }
                        @if (todayBookings.Any())
                        {
                            <ul class="list-unstyled mb-0">
                                @foreach (var booking in todayBookings)
                                {
                                    <li class="mb-2">
                                        <span style="font-size: 1.1rem;">🔔</span>
                                        <strong>@booking.Event?.EventName</strong>
                                        at @booking.BookingDate.ToString("HH:mm")
                                        <span class="text-muted">
                                            <span style="font-size: 1rem;">🏛️</span>
                                            @booking.Venue?.VenueName
                                        </span>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p class="text-muted mb-0">
                                <span style="font-size: 1.1rem;">😴</span> No bookings for today
                            </p>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-4">
            <div class="col-md-6">
                <div class="card bg-light-blue border-primary">
                    <div class="card-body">
                        <h5 class="card-title text-primary">
                            <span style="font-size: 1.5rem;">🏛️</span> Most Popular Venues
                        </h5>
                        @{
                            var popularVenues = Model
                            .Where(b => b.Venue != null)
                            .GroupBy(b => b.Venue.VenueName)
                            .Select(g => new { Venue = g.Key, Count = g.Count() })
                            .OrderByDescending(v => v.Count)
                            .Take(3);
                        }
                        @if (popularVenues.Any())
                        {
                            <ul class="list-unstyled mb-0">
                                @foreach (var venue in popularVenues)
                                {
                                    <li class="mb-2">
                                        <span style="font-size: 1.1rem;">🏆</span>
                                        <strong>@venue.Venue</strong>
                                        <span class="badge bg-primary rounded-pill">
                                            @venue.Count booking@(venue.Count != 1 ? "s" : "")
                                        </span>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p class="text-muted mb-0">
                                <span style="font-size: 1.1rem;">📊</span> No venue data available
                            </p>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card bg-light-blue border-primary">
                    <div class="card-body">
                        <h5 class="card-title text-primary">
                            <span style="font-size: 1.5rem;">ℹ️</span> Quick Tips
                        </h5>
                        <ul class="list-unstyled mb-0">
                            <li><span style="font-size: 1.1rem;">✅</span> Click <strong>Edit</strong> ✏️ to modify booking details</li>
                            <li><span style="font-size: 1.1rem;">✅</span> Click <strong>Details</strong> 🔍 to view full information</li>
                            <li><span style="font-size: 1.1rem;">✅</span> Click <strong>Delete</strong> 🗑️ to remove a booking</li>
                            <li><span style="font-size: 1.1rem;">🔮</span> <strong>Far out</strong> - Bookings more than 7 days away</li>
                            <li><span style="font-size: 1.1rem;">✅</span> <strong>Confirmed</strong> - Upcoming bookings</li>
                            <li><span style="font-size: 1.1rem;">🔥</span> <strong>Today</strong> - Bookings happening now</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    }
</div>