@model EventEaseApp.Models.Booking
@inject EventEaseApp.Models.EventEaseDbContext _context

@{
    ViewData["Title"] = "Create Booking";
    var events = new SelectList(_context.Events, "EventId", "EventName");
    var venues = new SelectList(_context.Venues, "VenueId", "VenueName");
}

<div class="container">
    <h1>Create New Booking</h1>

    <div class="row">
        <div class="col-md-8">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group mb-3">
                    <label asp-for="EventId" class="control-label">Select Event</label>
                    <select asp-for="EventId" class="form-control" asp-items="events">
                        <option value="">-- Select Event --</option>
                    </select>
                    <span asp-validation-for="EventId" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="VenueId" class="control-label">Select Venue</label>
                    <select asp-for="VenueId" class="form-control" asp-items="venues">
                        <option value="">-- Select Venue --</option>
                    </select>
                    <span asp-validation-for="VenueId" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="BookingDate" class="control-label"></label>
                    <input asp-for="BookingDate" class="form-control" type="datetime-local" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                    <span asp-validation-for="BookingDate" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <input type="submit" value="Create" class="btn btn-primary" />
                    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}