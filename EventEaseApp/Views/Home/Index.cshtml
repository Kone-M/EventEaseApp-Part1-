@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">
        <i class="bi bi-emoji-smile text-primary" style="font-size: 3rem;"></i>
        <i class="bi bi-calendar-event text-primary" style="font-size: 3rem;"></i>
        <i class="bi bi-building text-primary" style="font-size: 3rem;"></i>
        <br />
        Welcome to EventEase
    </h1>
    <p class="lead">
        <i class="bi bi-star-fill text-warning"></i>
        Venue Booking Management System
        <i class="bi bi-star-fill text-warning"></i>
    </p>
</div>

<div class="row mt-5">
    <div class="col-md-4 mb-4">
        <div class="card text-center h-100 shadow-sm border-primary">
            <div class="card-body">
                <i class="bi bi-building display-1 text-primary"></i>
                <h5 class="card-title mt-3">Venues</h5>
                <p class="card-text">
                    <i class="bi bi-geo-alt-fill text-primary"></i>
                    Manage venue information
                </p>
                <a href="@Url.Action("Index", "Venues")" class="btn btn-primary">
                    Go to Venues <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card text-center h-100 shadow-sm border-primary">
            <div class="card-body">
                <i class="bi bi-calendar-event display-1 text-primary"></i>
                <h5 class="card-title mt-3">Events</h5>
                <p class="card-text">
                    <i class="bi bi-megaphone-fill text-primary"></i>
                    Manage event information
                </p>
                <a href="@Url.Action("Index", "Events")" class="btn btn-primary">
                    Go to Events <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card text-center h-100 shadow-sm border-primary">
            <div class="card-body">
                <i class="bi bi-journal-bookmark-fill display-1 text-primary"></i>
                <h5 class="card-title mt-3">Bookings</h5>
                <p class="card-text">
                    <i class="bi bi-check-circle-fill text-primary"></i>
                    Manage venue bookings
                </p>
                <a href="@Url.Action("Index", "Bookings")" class="btn btn-primary">
                    Go to Bookings <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>
</div>